- content_for(:title) { "Map: #{@map.title} (Edit)" }


#form-wrapper
  %p.text-right.close_link_wrapper
    =link_to maps_path, :class=>'close_link' do
      %i.fi.fi-x
  %p
    Map:
    = link_to map_layers_path(@map) do
      = @map.title
  .grid-x.grid-padding-x
    .large-6.medium-6.small-6.cell
      %h1
        =@map.title
    .large-6.medium-6.small-6.cell
      - if @map && @map.created_at
        %p.shy
          Created:
          = l(@map.created_at)
          %br
          Layers:
          = @map.layers.count
          - if @map.pages.count > 0
            \| Pages:
            = @map.pages.count
          - if @map.available_languages.present?
            %br
              =@map.primary_language.present? ? "Primary language: #{@map.primary_language}" : "Primary language not set"
              \| Alternatives:
              = @map.available_languages.join(', ')

  = render 'form'
