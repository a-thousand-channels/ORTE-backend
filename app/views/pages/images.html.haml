- content_for(:title) { "Pages of #{@map.title}" }

#table-wrapper
  %p.text-right.close_link_wrapper
    =link_to map_path(@map), :class=>'close_link' do
      %i.fi.fi-x
  %h1
    Images:
    = link_to map_page_path(@map,@page) do
      = @page.title
    %hr
  - @page.places.each_slice(4) do | batch |
    .grid-x.grid-padding-x.grid-images
      - batch.each do | place |
        .cell.small-12.medium-3.large-3
          %div.gallery
            = link_to map_page_place_path(@map,@page,place) do
              = place.title
            %hr

            - if place.images.count > 0
              - place.images.each do |img|
                - if img.attached? && ActiveStorage::Blob.service.exist?(img.blob.key)
                  - if img.preview.present?
                    %p{"data-open": "reveal#{img.id}"}
                      = link_to map_page_place_image_path(place.page.map,place.page,place,img), class: "thumbnail thumbnail-preview" do
                        = image_tag img.file.variant(resize: "400x400").processed
                        = image_tag img.file.variant(resize: "400x400", "ordered-dither": "h4x4a").processed
                  - else
                    %p{"data-open": "reveal#{img.id}"}
                      = link_to map_page_place_image_path(place.page.map,place.page,place,img), class: "thumbnail" do
                        = image_tag img.file.variant(resize: "400x400").processed
                        = image_tag img.file.variant(resize: "400x400", "ordered-dither": "h4x4a").processed
            - else
              %p.small.shy No images (yet)

